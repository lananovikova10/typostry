NEXT_PUBLIC_APP_URL=http://localhost:3000

# Unsplash API credentials - used for fetching images
# Server-side only - do not expose in client
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
UNSPLASH_SECRET_KEY=your_unsplash_secret_key
# Public key that can be exposed to the client
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# GitLab API configuration for templates
NEXT_PUBLIC_GITLAB_REPO_URL=https://gitlab.com/tgdp/templates
NEXT_PUBLIC_GITLAB_TOKEN=your_gitlab_token

# JetBrains Grazie NLC API authentication
# Get your token from: https://account.jetbrains.com/
# Required for text completion features
# Note: Token is accessed server-side only for security
GRAZIE_TOKEN=your_grazie_jwt_token

# Hugging Face API credentials - used for AI summarization feature
# Get your token from: https://huggingface.co/settings/tokens
# Can be exposed to client (NEXT_PUBLIC_*) or kept server-side only
NEXT_PUBLIC_HF_API_KEY=your_huggingface_api_key
# Alternatively, use HF_API_KEY for server-side only access
# HF_API_KEY=your_huggingface_api_key